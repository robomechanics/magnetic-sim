<!-- Robot fragment — included by scene.xml. No <mujoco> wrapper. -->
<mujocoinclude>
<compiler angle="radian" meshdir="assets" autolimits="true"/>

<option timestep="0.001" integrator="implicit" gravity="0 0 -9.81"/>

<default>
  <default class="mwc_mjcf">
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.2 0.4 0.9 0.4"/>
    </default>
    <default class="collision">
      <geom group="3" rgba="0 0 0 0" condim="6"/>
    </default>
  </default>
</default>

<worldbody>
  <!-- Root body: fixed base assembly -->
  <body name="base" pos="0 0 0.025" quat="-0.7071068 0.7071068 0 0">
    <freejoint name="base_free"/>
    <!-- Magnet bracket -->
    <body name="1102___pf___magnet_bracket" pos="-0.0660751 0.00635001 0.000345108">
      <geom type="mesh" class="visual" mesh="1102___pf___magnet_bracket"/>
      <geom type="mesh" class="collision" mesh="1102___pf___magnet_bracket" density="1250"/>
    </body>

    <!-- Roller chain attachment 1 -->
    <body name="1101___pp___roller_chain_1" pos="-0.126746 0 -0.0091799" quat="0.707107 0 -0.707107 0">
      <geom type="mesh" class="visual" mesh="1101___pp___roller_chain_attachment_link__7321k1"/>
      <geom type="mesh" class="collision" mesh="1101___pp___roller_chain_attachment_link__7321k1" density="1250"/>
      <geom type="mesh" class="visual" mesh="1101___pp___roller_chain_attachment_link__7321k1__2"/>
      <geom type="mesh" class="collision" mesh="1101___pp___roller_chain_attachment_link__7321k1__2" density="1250"/>
