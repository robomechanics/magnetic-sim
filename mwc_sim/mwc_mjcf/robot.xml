  <material name="1101___pp___roller_chain_attachment_link__7321k1__2_material"     rgba="0.2 0.4 0.9 0.4"/>
  <material name="1103___pp___aws_pem_215lbs__eml63mm_24_material"                  rgba="0.9 0.1 0.1 0.35"/>
