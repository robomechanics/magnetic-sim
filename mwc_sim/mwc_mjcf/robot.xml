      <geom type="mesh" class="visual" mesh="1101___pp___roller_chain_attachment_link__7321k1__2"/>
      <geom type="mesh" class="collision" mesh="1101___pp___roller_chain_attachment_link__7321k1__2" density="1250"/>
    </body>

    <!-- Electromagnet (AWS PEM 215lbs EML63mm) — rigid, no joint -->
    <body name="1103___pp___aws_pem_215lbs__eml63mm_24" pos="-0.066075 -0.0176499 0.000345139">
      <geom type="mesh" class="visual" mesh="1103___pp___aws_pem_215lbs__eml63mm_24" rgba="0.9 0.1 0.1 0.35"/>
      <geom type="mesh" class="collision" mesh="1103___pp___aws_pem_215lbs__eml63mm_24" density="7800"/>

      <!-- Bottom ring sampling spheres: ring in XZ plane, Y is face-normal offset -->
      <!-- RADIUS=0.025, EMBED_R=0.003 → ring_r=0.022; HALF_HEIGHT=0.0125, EMBED_Z=0.002 → y=+0.0105 -->
      <geom type="sphere" size="0.002" pos="+0.022000 +0.012500 +0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="+0.015556 +0.012500 +0.015556" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="+0.000000 +0.012500 +0.022000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.015556 +0.012500 +0.015556" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.022000 +0.012500 +0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
