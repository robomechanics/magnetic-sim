      <geom type="sphere" size="0.002" pos="+0.015556 +0.012500 -0.015556" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>

      <!-- Lever arm stick: extends in +Y (away from plate face), half-length=0.035 → tip at y=+0.0825 -->
      <body name="stick" pos="0 -0.0275 0">
        <geom name="stick_geom" type="cylinder" size="0.004 0.035"
              euler="1.5707963 0 0"
              rgba="0.9 0.7 0.1 0.8" contype="0" conaffinity="0" mass="1e-6"/>
        <site name="stick_tip" pos="0 -0.035 0" size="0.006" rgba="1 0 0 1"/>
      </body>
    </body>

  </body>

  <body name="plate" pos="0 0 0">
    <geom name="plate_geom" type="box" pos="0 0 -0.005" size="0.25 0.25 0.005"
          rgba="0.6 0.65 0.7 1" condim="6"/>
