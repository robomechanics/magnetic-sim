<?xml version="1.0" encoding="utf-8"?>
<mujoco model="magnet_wrench_test">
  <compiler angle="radian" autolimits="true" />

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.9 0.9 0.9" rgb2="0.7 0.7 0.7"/>
    <material name="grid" texture="grid" texrepeat="5 5" reflectance="0.2"/>
    <texture name="skybox" type="skybox" builtin="gradient"
             rgb1="0.8 0.85 0.9" rgb2="0.95 0.95 0.95" width="512" height="512"/>
  </asset>

  <option timestep="0.001" integrator="implicit" gravity="0 0 -9.81" />

  <default>
    <geom condim="6" contype="1" conaffinity="1" friction="0.8 0.1 0.1" rgba="0.7 0.7 0.7 1" />
  </default>

  <worldbody>
    <geom name="floor" type="plane" size="1 1 0.01" material="grid"
          pos="0 0 -0.015" contype="0" conaffinity="0"/>

    <!-- Plate lies flat: top surface at z=0 -->
    <body name="plate" pos="0 0 0">
      <geom name="plate_geom" type="box" pos="0 0 -0.005" size="0.25 0.25 0.005"
            rgba="0.6 0.65 0.7 1" />
    </body>

    <!-- Magnet + stick assembly: freejoint for full 6-DOF motion -->
    <!-- Magnet center starts at z=0.0125 (face flush with plate top at z=0) -->
    <body name="magnet" pos="0 0 0.0125">
      <freejoint name="magnet_free"/>

      <!-- Magnet: r=31.5mm, half-height=12.5mm -->
      <geom name="magnet_cyl" type="cylinder" size="0.0315 0.0125"
            rgba="0.85 0.1 0.1 1" density="7500" />

      <!-- Stick: r=15mm, half-length=35mm, rigidly attached.
           Stick center at z = 0.0125 (magnet half-h) + 0.035 (stick half-l) = 0.0475
           above magnet center, so pos="0 0 0.0475" in body frame -->
      <geom name="stick" type="cylinder" size="0.015 0.035"
            pos="0 0 0.0475" rgba="0.3 0.6 0.9 1" density="1200" />

      <!-- Sampling spheres (3 rings x 8 pts = 24). Non-colliding. -->
      <!-- Bottom ring (z=-0.0105): closest to plate -->
      <geom type="sphere" size="0.002" pos=" 0.028500  0.000000 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152  0.020152 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000  0.028500 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152  0.020152 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.028500  0.000000 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152 -0.020152 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000 -0.028500 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152 -0.020152 -0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <!-- Middle ring (z=0) -->
      <geom type="sphere" size="0.002" pos=" 0.028500  0.000000  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152  0.020152  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000  0.028500  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152  0.020152  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.028500  0.000000  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152 -0.020152  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000 -0.028500  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152 -0.020152  0.000000" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <!-- Top ring (z=+0.0105) -->
      <geom type="sphere" size="0.002" pos=" 0.028500  0.000000  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152  0.020152  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000  0.028500  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152  0.020152  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.028500  0.000000  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos="-0.020152 -0.020152  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.000000 -0.028500  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
      <geom type="sphere" size="0.002" pos=" 0.020152 -0.020152  0.010500" contype="0" conaffinity="0" mass="1e-6" rgba="0 0 1 1"/>
    </body>
  </worldbody>
</mujoco>