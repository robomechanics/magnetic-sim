<mujoco model="magnet_wall_env">
    <compiler angle="radian"/>
    <option integrator="implicit" cone="elliptic" impratio="10" noslip_iterations="15"/>

    <default class="main">
        <geom condim="6"/>
    </default>

    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>

    <worldbody>

        <!-- === Vertical Magnetic Wall === -->
        <!-- Positioned vertically, normal along +X -->
        <body name="wall" pos="0.205 0 0.205">
            <geom name="magnetic_wall" type="box" size="0.02 0.25 0.25"/>
        </body>


        <!-- === Magnet wheel adhering to wall === -->
        <!-- Axis along X, with ~2 mm air gap before contact -->
        <!-- Added 10° tilt around Z-axis -->
        <body name="magnet_wheel" pos="0.125 0 0.15" euler="0 0 0.174533"> <!-- 10° = 0.174533 rad -->
            <inertial mass="0.33" pos="0 0 0"
                      diaginertia="0.000069 0.000103 0.000069"/>

            <freejoint/>

            <!-- Main magnet cylinder -->
            <geom name="magnet_geom" type="cylinder" size="0.025 0.0125"
                  rgba="0.8 0.2 0.2 0.8"
                  friction="1 0.01 0.01"/>

            <!-- Magnetic contact points — 3 rings of 8, all embedded (0.025-pos's first value) mm inside cylinder face -->
            <geom name="mag_pt0_f" type="sphere" size="0.001" pos="0  0  0"/>
            <!-- <geom name="mag_pt1_f" type="sphere" size="0.001" pos="0.010 -0.018  0.0125"/>
            <geom name="mag_pt2_f" type="sphere" size="0.001" pos="0.010  0.018 -0.0125"/>
            <geom name="mag_pt3_f" type="sphere" size="0.001" pos="0.010 -0.018 -0.0125"/>
            <geom name="mag_pt4_f" type="sphere" size="0.001" pos="0.010  0.000  0.000"/>
            <geom name="mag_pt5_f" type="sphere" size="0.001" pos="0.010  0.025  0.000"/>
            <geom name="mag_pt6_f" type="sphere" size="0.001" pos="0.010 -0.025  0.000"/>
            <geom name="mag_pt7_f" type="sphere" size="0.001" pos="0.010  0.000  0.0125"/>

            <geom name="mag_pt0_m" type="sphere" size="0.001" pos="0.010  0.018  0.0125"/>
            <geom name="mag_pt1_m" type="sphere" size="0.001" pos="0.010 -0.018  0.0125"/>
            <geom name="mag_pt2_m" type="sphere" size="0.001" pos="0.010  0.018 -0.0125"/>
            <geom name="mag_pt3_m" type="sphere" size="0.001" pos="0.010 -0.018 -0.0125"/>
            <geom name="mag_pt4_m" type="sphere" size="0.001" pos="0.010  0.000  0.000"/>
            <geom name="mag_pt5_m" type="sphere" size="0.001" pos="0.010  0.025  0.000"/>
            <geom name="mag_pt6_m" type="sphere" size="0.001" pos="0.010 -0.025  0.000"/>
            <geom name="mag_pt7_m" type="sphere" size="0.001" pos="0.010  0.000  0.0125"/>

            <geom name="mag_pt0_b" type="sphere" size="0.001" pos="0.010  0.018  0.0125"/>
            <geom name="mag_pt1_b" type="sphere" size="0.001" pos="0.010 -0.018  0.0125"/>
            <geom name="mag_pt2_b" type="sphere" size="0.001" pos="0.010  0.018 -0.0125"/>
            <geom name="mag_pt3_b" type="sphere" size="0.001" pos="0.010 -0.018 -0.0125"/>
            <geom name="mag_pt4_b" type="sphere" size="0.001" pos="0.010  0.000  0.000"/>
            <geom name="mag_pt5_b" type="sphere" size="0.001" pos="0.010  0.025  0.000"/>
            <geom name="mag_pt6_b" type="sphere" size="0.001" pos="0.010 -0.025  0.000"/>
            <geom name="mag_pt7_b" type="sphere" size="0.001" pos="0.010  0.000  0.0125"/> -->


        </body>

    </worldbody>
</mujoco>
