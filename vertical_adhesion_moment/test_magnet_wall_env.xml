<mujoco model="magnet_wall_env">
    <compiler angle="radian"/>
    <option integrator="implicit" cone="elliptic" impratio="10" noslip_iterations="15"/>

    <default class="main">
        <geom condim="6"/>
    </default>

    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>

    <worldbody>

        <!-- === Vertical Magnetic Wall === -->
        <!-- Positioned vertically, normal along +X -->
        <body name="wall" pos="0.18 0 0.18">
            <geom name="magnetic_wall" type="box" size="0.02 0.25 0.25"/>
        </body>


        <!-- === Magnet wheel adhering to wall === -->
        <!-- Axis along X, with ~2 mm air gap before contact -->
        <body name="magnet_wheel" pos="0.125 0 0.15" zaxis="0 0 1">
            <inertial mass="0.33" pos="0 0 0"
                    diaginertia="0.000069 0.000103 0.000069"/>

            <freejoint/>

            <!-- Main magnet cylinder -->
             <geom name="magnet_geom" type="cylinder" size="0.025 0.0125"
                rgba="0.8 0.2 0.2 0.8"
                friction="1 0.01 0.01"/>

            <!-- Magnetic contact points — front face touching wall -->
            <geom name="mag_pt0" type="sphere" size="0.001" pos="0.025  0.018  0.0125"/>
            <geom name="mag_pt1" type="sphere" size="0.001" pos="0.025 -0.018  0.0125"/>
            <geom name="mag_pt2" type="sphere" size="0.001" pos="0.025  0.018 -0.0125"/>
            <geom name="mag_pt3" type="sphere" size="0.001" pos="0.025 -0.018 -0.0125"/>
            <geom name="mag_pt4" type="sphere" size="0.001" pos="0.025  0.000  0.000"/>
            <geom name="mag_pt5" type="sphere" size="0.001" pos="0.025  0.025  0.000"/>
            <geom name="mag_pt6" type="sphere" size="0.001" pos="0.025 -0.025  0.000"/>
            <geom name="mag_pt7" type="sphere" size="0.001" pos="0.025  0.000  0.0125"/>
        </body>

    </worldbody>
</mujoco>
